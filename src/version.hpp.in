#ifndef VERSION_HPP
#define VERSION_HPP

namespace sm_version {
	constexpr int major = @SM_VERSION_MAJOR@;
	constexpr int minor = @SM_VERSION_MINOR@;
	constexpr int patch = @SM_VERSION_PATCH@;
	constexpr const char* git_hash = "@SM_VERSION_GIT_HASH@";
	constexpr const char* git = "@SM_VERSION_GIT@";
	constexpr const char* traditional = "@SM_VERSION_TRADITIONAL@";
	constexpr const char* timestamp_date = "@SM_TIMESTAMP_DATE@";
	constexpr const char* timestamp_time = "@SM_TIMESTAMP_TIME@";
}

/* Legacy compatibility exports for code using extern declarations */
namespace {
	extern const int sm_version_major = sm_version::major;
	extern const int sm_version_minor = sm_version::minor;
	extern const int sm_version_patch = sm_version::patch;
	extern const char* const sm_version_git_hash = sm_version::git_hash;
	extern const char* const version_date = sm_version::timestamp_date;
	extern const char* const version_time = sm_version::timestamp_time;
	extern const char* const product_version = sm_version::git;
}

#endif

// clang-format off
#ifndef VERSION_HPP
#define VERSION_HPP

namespace sm_version {
	inline constexpr int major = @SM_VERSION_MAJOR@;
	inline constexpr int minor = @SM_VERSION_MINOR@;
	inline constexpr int patch = @SM_VERSION_PATCH@;
	inline constexpr char const* git_hash = "@SM_VERSION_GIT_HASH@";
	inline constexpr char const* git = "@SM_VERSION_GIT@";
	inline constexpr char const* traditional = "@SM_VERSION_TRADITIONAL@";
	inline constexpr char const* timestamp_date = "@SM_TIMESTAMP_DATE@";
	inline constexpr char const* timestamp_time = "@SM_TIMESTAMP_TIME@";
}

// Legacy globals
inline constexpr char const* const product_version = sm_version::git;
inline constexpr unsigned long version_num = 0;
inline constexpr char const* const version_time = sm_version::timestamp_time;
inline constexpr char const* const version_date = sm_version::timestamp_date;
inline constexpr char const* const sm_version_git_hash = sm_version::git_hash;

#endif
// clang-format on
#ifndef VERSION_HPP
#define VERSION_HPP

namespace sm_version {
	constexpr int major = @SM_VERSION_MAJOR@;
	constexpr int minor = @SM_VERSION_MINOR@;
	constexpr int patch = @SM_VERSION_PATCH@;
	constexpr const char* git_hash = "@SM_VERSION_GIT_HASH@";
	constexpr const char* git = "@SM_VERSION_GIT@";
	constexpr const char* traditional = "@SM_VERSION_TRADITIONAL@";
	constexpr const char* timestamp_date = "@SM_TIMESTAMP_DATE@";
	constexpr const char* timestamp_time = "@SM_TIMESTAMP_TIME@";
}

// Extern symbols for backward compatibility with existing code
extern char const * const product_version;
extern unsigned long const version_num;
extern char const * const version_time;
extern char const * const version_date;
extern char const * const sm_version_git_hash;

#endif
